{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.test.tsbuildinfo",
    "target": "es2023",
    "module": "esnext",
    "types": ["node", "vitest/globals"],
    "noEmit": true,
    "moduleDetection": "force",
    "resolveJsonModule": true
  },
  "include": ["src/**/*.test.ts", "vitest.config.ts"]
}
